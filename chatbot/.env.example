# AWS Bedrock Configuration
# Required: AWS credentials for Bedrock Nova Pro access
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Optional: AWS session token for temporary credentials
# AWS_SESSION_TOKEN=your_session_token_here

# Optional: Bearer token for alternative Bedrock authentication
# AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_here

# AWS region for Bedrock service (default: us-east-1)
AWS_REGION=us-east-1

# Backend API Configuration
# Required: Base URL of the Node.js backend API
BACKEND_API_URL=http://localhost:5000

# Optional: Timeout for backend API calls in seconds (default: 5)
BACKEND_API_TIMEOUT=5

# HTTP Server Configuration
# Optional: Port for the chatbot service (default: 8000)
CHATBOT_PORT=8000

# Optional: Host binding (default: 0.0.0.0)
CHATBOT_HOST=0.0.0.0

# Logging Configuration
# Optional: Log level - DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Service Configuration
# Optional: Service version (default: 1.0.0)
SERVICE_VERSION=1.0.0

# Optional: Maximum words in chatbot responses (default: 500)
MAX_RESPONSE_WORDS=500

# Optional: Session expiration time in hours (default: 24)
SESSION_MAX_AGE_HOURS=24

# CORS Configuration
# Optional: Allowed CORS origins (default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000
